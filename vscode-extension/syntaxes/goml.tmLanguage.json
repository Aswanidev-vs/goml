{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GOML",
  "scopeName": "source.goml",
  "patterns": [
    { "include": "#comments" },
    { "include": "#references" },
    { "include": "#key-value" },
    { "include": "#block-start" },
    { "include": "#arrays" },
    { "include": "#values" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.goml",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.goml",
          "match": "//.*$"
        },
        {
          "name": "comment.block.goml",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.goml" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.goml" }
          }
        }
      ]
    },
    "references": {
      "patterns": [
        {
          "name": "variable.other.reference.goml",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_.-]*"
        }
      ]
    },
    "strings-double": {
      "patterns": [
        {
          "name": "string.quoted.double.goml",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.goml" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.goml" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.goml",
              "match": "\\\\(?:[ntr\\\\\"'])"
            }
          ]
        }
      ]
    },
    "strings-single": {
      "patterns": [
        {
          "name": "string.quoted.single.goml",
          "begin": "'",
          "end": "'",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.goml" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.goml" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        { "include": "#strings-double" },
        { "include": "#strings-single" }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.goml",
          "match": "-?\\d+\\.\\d+"
        },
        {
          "name": "constant.numeric.integer.goml",
          "match": "-?\\d+"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.goml",
          "match": "\\b(true)\\b"
        },
        {
          "name": "constant.language.boolean.false.goml",
          "match": "\\b(false)\\b"
        }
      ]
    },
    "null-values": {
      "patterns": [
        {
          "name": "constant.language.null.goml",
          "match": "\\b(null)\\b"
        },
        {
          "name": "constant.language.null.goml",
          "match": "(?<=\\s|^)~(?=\\s|$)"
        }
      ]
    },
    "values": {
      "patterns": [
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#booleans" },
        { "include": "#null-values" },
        { "include": "#references" }
      ]
    },
    "key-value": {
      "patterns": [
        {
          "match": "^\\s*(\\w[\\w.-]*)\\s*(=)",
          "captures": {
            "1": { "name": "entity.name.tag.key.goml" },
            "2": { "name": "keyword.operator.assignment.goml" }
          }
        }
      ]
    },
    "block-start": {
      "patterns": [
        {
          "match": "^\\s*(\\w[\\w.-]*)\\s*(\\{)",
          "captures": {
            "1": { "name": "entity.name.tag.block.goml" },
            "2": { "name": "punctuation.section.block.begin.goml" }
          }
        },
        {
          "match": "(\\})",
          "captures": {
            "1": { "name": "punctuation.section.block.end.goml" }
          }
        }
      ]
    },
    "arrays": {
      "patterns": [
        {
          "match": "^\\s*(\\w[\\w.-]*)\\s*(\\=)\\s*(\\[)",
          "captures": {
            "1": { "name": "entity.name.tag.key.goml" },
            "2": { "name": "keyword.operator.assignment.goml" },
            "3": { "name": "punctuation.section.array.begin.goml" }
          }
        },
        {
          "match": "(\\])",
          "captures": {
            "1": { "name": "punctuation.section.array.end.goml" }
          }
        },
        {
          "match": "(,)",
          "captures": {
            "1": { "name": "punctuation.separator.comma.goml" }
          }
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "match": "(=)",
          "captures": {
            "1": { "name": "keyword.operator.assignment.goml" }
          }
        },
        {
          "match": "(\\{)",
          "captures": {
            "1": { "name": "punctuation.section.block.begin.goml" }
          }
        },
        {
          "match": "(\\})",
          "captures": {
            "1": { "name": "punctuation.section.block.end.goml" }
          }
        },
        {
          "match": "(\\[)",
          "captures": {
            "1": { "name": "punctuation.section.array.begin.goml" }
          }
        },
        {
          "match": "(\\])",
          "captures": {
            "1": { "name": "punctuation.section.array.end.goml" }
          }
        }
      ]
    }
  }
}
